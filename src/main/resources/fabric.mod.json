			"soullessberry.enchantmenteffects.EnchantmentEffects"
		],
		"client": [
			"soullessberry.enchantmenteffects.EnchantmentEffectsClient"
		]
	},
	"mixins": [
		"enchantment-effects.mixins.json"
	],
	"depends": {
