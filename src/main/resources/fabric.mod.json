{
	"schemaVersion": 1,
	"id": "enchantment-effects",
	"version": "${version}",
	"name": "Enchantment Effects",
	"description": "Adds client-side effects for enchantments!",
	"authors": [
		"soullessberry"
	],
	"contact": {
		"sources": "https://github.com/soullessberry/enchantment-effects"
	},
	"license": "MIT",
	"icon": "assets/enchantment-effects/icon.png",
	"environment": "client",
	"entrypoints": {
